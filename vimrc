set nobackup
set nocompatible
set modelines=0
set number
set encoding=utf-8
set nowrap
set tabstop=4
set shiftwidth=4
set softtabstop=4
set noautoindent
set copyindent
set expandtab
set noshiftround
set hlsearch
set incsearch
set showmatch
set nosmartcase
set hidden
set showcmd
set background=dark
set laststatus=2
set nocindent

filetype indent on
syntax on
inoremap jj <ESC>
